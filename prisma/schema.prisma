generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Symbol {
  id              String    @id @default(uuid())
  name            String    @unique
  fundingRate     Float?
  nextFundingTime DateTime?
  fundingInterval Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
}
