generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Symbol {
  id              String    @id @default(uuid())
  name            String    @unique
  fundingRate     Float?
  nextFundingTime DateTime?
  fundingInterval Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
}

model Order {
  id             String   @id @default(uuid())
  symbol         String
  side           String   // BUY or SELL
  quantity       Float
  entryPrice     Float?
  exitPrice      Float?
  profit         Float?
  binanceOrderId String?
  status         String   @default("OPEN") // OPEN, CLOSED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([symbol])
}

model ScheduledOrder {
  id        String   @id
  label     String
  executeAt DateTime
  type      String   // BUY | SELL | CLOSE_SINGLE | CLOSE_ALL
  params    Json
  createdAt DateTime @default(now())

  @@index([executeAt])
}
