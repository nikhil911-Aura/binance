generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Symbol {
  id              String    @id @default(uuid())
  name            String    @unique
  fundingRate     Float?
  nextFundingTime DateTime?
  fundingInterval Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([name])
}

model Order {
  id             String   @id @default(uuid())
  symbol         String
  side           String   // BUY or SELL
  quantity       Float
  entryPrice     Float?
  exitPrice      Float?
  profit         Float?
  binanceOrderId       String?
  pendingCloseOrderId  String? // set when a limit close is placed but not yet filled
  pendingClosePrice    Float?  // limit price for pending close order
  stopLoss             Float?  // auto-close when mark price crosses this level
  status               String   @default("OPEN") // OPEN, CLOSED, PENDING
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([symbol])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PriceHistory {
  id       BigInt   @id @default(autoincrement())
  symbol   String
  openTime DateTime
  open     Float
  high     Float
  low      Float
  close    Float
  volume   Float

  @@unique([symbol, openTime])
  @@index([symbol, openTime])
  @@index([openTime])
}

model ScheduledOrder {
  id        String   @id
  label     String
  executeAt DateTime
  type      String   // BUY | SELL | CLOSE_SINGLE | CLOSE_ALL
  params    Json
  createdAt DateTime @default(now())

  @@index([executeAt])
}

model FundingWindowPrice {
  id          BigInt   @id @default(autoincrement())
  symbol      String
  price       Float
  recordedAt  DateTime
  fundingTime DateTime
  fundingRate Float
  phase       String   // "before" | "after"

  @@index([symbol, fundingTime])
  @@index([fundingTime])
}
